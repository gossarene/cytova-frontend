# Cytova Frontend Environment Variables
# Copy to .env.local and fill in values

# API base URL (relative in dev with Vite proxy, absolute in production)
VITE_API_BASE_URL=/api/v1

# Platform admin API base URL
VITE_PLATFORM_API_BASE_URL=https://admin.cytova.io/api/v1/platform

# Application name
VITE_APP_NAME=Cytova
